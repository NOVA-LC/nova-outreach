# Supabase --------------------------------------------------------
# URL is project-specific; copy as-is.
SUPABASE_URL=https://sqsaixsqxavcfklovkbw.supabase.co
# SERVICE ROLE key — Supabase Dashboard → Project Settings → API → service_role (secret).
# DO NOT commit this. Set in Vercel env vars only.
SUPABASE_SERVICE_ROLE_KEY=

# Resend ----------------------------------------------------------
RESEND_API_KEY=re_PezewVYA_FE1Lzeypx3uhwoLt6iqohri8
# Generated below; used to validate inbound webhooks. Set when you create the webhook in Resend dashboard.
RESEND_WEBHOOK_SECRET=

# App -------------------------------------------------------------
# Public URL of this Vercel deployment, used for tracking link generation.
APP_URL=https://nova-outreach.vercel.app
# Random token; Vercel cron sends this in Authorization header. Match against env.
CRON_SECRET=
# Random token used in /api/scrape manual triggers.
SCRAPE_SECRET=

# Brave Search API ------------------------------------------------
# Optional. Free 2,000 queries/month. https://api.search.brave.com/app/keys
# When set, the discover scraper rotates through 18 states + 4 query templates
# daily, fetches result pages, and extracts agent emails autonomously.
# Leave blank → discover scraper is a no-op; rely on CSV import + curated directories.
BRAVE_SEARCH_API_KEY=

# Sender identity -------------------------------------------------
# Using tyler@gonenova.com (already-warmed inbox = better day-1 deliverability).
# Resend verifies the domain; you can send from any address on gonenova.com.
FROM_EMAIL=tyler@gonenova.com
FROM_NAME=Tyler
REPLY_TO=tyler@gonenova.com

# Compliance ------------------------------------------------------
# Required CAN-SPAM physical address. Use a real mailing address you can receive at.
COMPLIANCE_ADDRESS=Nova Intel, [STREET ADDRESS], Atlanta, GA [ZIP]

# Twilio (later, once 10DLC clears) -------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# Warmup safety ---------------------------------------------------
# Hard cap on emails per day. Tonight: 100 (warmed inbox), Day 2: 150, Day 3: 250, Week 2: 500.
DAILY_SEND_CAP=100
# Per-cron-run cap (we run every 30 min from 13:00–22:00 UTC = 9–6 ET, weekdays = 19 runs).
# 100 / 19 ≈ 6 per run for tonight's pace.
PER_RUN_CAP=6
